<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="end|center_vertical"
            android:text="0"
            android:textSize="16sp"
            android:textColor="#666666"
            android:paddingEnd="8dp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="end|center_vertical"
            android:text="0"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingEnd="8dp"
            android:paddingBottom="6dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="5"
            android:rowCount="7"
            android:useDefaultMargins="false">

            <Button android:id="@+id/btnSin"
                android:text="sin"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnCos"
                android:text="cos"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnTan"
                android:text="tan"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnLog"
                android:text="log"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnLn"
                android:text="ln"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnSqrt"
                android:text="√"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnSquare"
                android:text="x²"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnPower"
                android:text="xʸ"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnPi"
                android:text="π"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnE"
                android:text="e"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnOpen"
                android:text="("
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnClose"
                android:text=")"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnPercent"
                android:text="%"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnDelete"
                android:text="DEL"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnClear"
                android:text="AC"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn7"
                android:text="7"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn8"
                android:text="8"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn9"
                android:text="9"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnDivide"
                android:text="÷"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnFactorial"
                android:text="!"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn4"
                android:text="4"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn5"
                android:text="5"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn6"
                android:text="6"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnMultiply"
                android:text="×"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnInverse"
                android:text="1/x"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn1"
                android:text="1"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn2"
                android:text="2"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn3"
                android:text="3"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnMinus"
                android:text="-"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnAns"
                android:text="Ans"
                android:textSize="11sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btn0"
                android:text="0"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnDot"
                android:text="."
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnEqual"
                android:text="="
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnPlus"
                android:text="+"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button android:id="@+id/btnNegate"
                android:text="±"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="52dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

        </GridLayout>

    </LinearLayout>

</ScrollView>